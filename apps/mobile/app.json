{
	"expo": {
		"name": "Newsroom — Daily Headlines",
		"slug": "newsroom",
		"version": "1.0.0",
		"scheme": "newsroom",
		"orientation": "portrait",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "automatic",
		"ios": {
			"supportsTablet": false,
			"bundleIdentifier": "com.mykelcodes.newsroom",
			"buildNumber": "1",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#0f0f0f",
				"foregroundImage": "./assets/android-icon-foreground.png",
				"backgroundImage": "./assets/android-icon-background.png",
				"monochromeImage": "./assets/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false,
			"package": "com.mykelcodes.newsroom",
			"versionCode": 1
		},
		"web": {
			"favicon": "./assets/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-font",
				{
					"fonts": ["./assets/fonts/Monoton-Regular.ttf"]
				}
			],
			"expo-web-browser",
			[
				"expo-dev-client",
				{
					"launchMode": "most-recent",
					"toolsButton": true,
					"skipOnboarding": false,
					"showMenuAtLaunch": true
				}
			],
			[
				"expo-splash-screen",
				{ "backgroundColor": "#0f0f0f", "image": "./assets/icon.png", "imageWidth": 200 }
			]
		]
	}
}
