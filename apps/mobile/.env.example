# Convex deployment URL the app talks to.
#
# Expo loads env files by mode:
#   .env             -> used by `expo start` (development)  -> point at DEV Convex
#   .env.production  -> used by local production builds       -> point at PROD Convex
#     (expo export, expo run:ios --configuration Release, run:android --variant release)
#
# Do NOT put EXPO_PUBLIC_CONVEX_URL in .env.local — it overrides .env.production
# in every mode and would send production builds to the wrong deployment.
EXPO_PUBLIC_CONVEX_URL=
