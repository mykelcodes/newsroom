{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"wrangler:types": "wrangler types"
	},
	"devDependencies": {
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@sveltejs/adapter-cloudflare": "7.2.9",
		"@sveltejs/kit": "2.69.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.2",
		"@types/node": "26.1.0",
		"eslint": "10.6.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.20.0",
		"globals": "17.7.0",
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "5.56.4",
		"svelte-check": "4.7.1",
		"tailwindcss": "4.3.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.62.1",
		"vite": "8.1.3",
		"wrangler": "4.107.0"
	},
	"dependencies": {
		"@newsroom/backend": "workspace:*",
		"convex": "1.42.1",
		"convex-svelte": "0.14.0",
		"dayjs": "1.11.21"
	}
}
