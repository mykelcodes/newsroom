{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"isolatedModules": true,
		"noEmit": true
	},
	"include": ["convex/**/*.ts"],
	"exclude": ["convex/_generated"]
}
