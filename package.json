{
	"name": "newsroom",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"pnpm convex:dev\" \"vite dev\"",
		"build": "wrangler types && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"wrangler:types": "wrangler types",
		"convex:dev": "convex dev",
		"convex:build": "convex build",
		"convex:deploy": "convex deploy"
	},
	"devDependencies": {
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.63.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.1",
		"concurrently": "10.0.3",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "4.1.0",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "5.56.2",
		"svelte-check": "4.6.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"vite": "8.0.16",
		"wrangler": "4.98.0"
	},
	"dependencies": {
		"convex": "1.40.0",
		"convex-svelte": "0.0.12",
		"dayjs": "1.11.21"
	}
}
