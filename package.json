{
	"name": "newsroom",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.6.0",
	"scripts": {
		"dev": "concurrently \"pnpm --filter @newsroom/backend dev\" \"pnpm --filter web dev\"",
		"dev:web": "pnpm --filter web dev",
		"dev:mobile": "pnpm --filter mobile start",
		"dev:backend": "pnpm --filter @newsroom/backend dev",
		"build:web": "pnpm --filter web build",
		"deploy:web": "pnpm --filter web run deploy",
		"convex:deploy": "pnpm --filter @newsroom/backend run deploy",
		"check": "pnpm -r --if-present check",
		"lint": "pnpm -r --if-present lint",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"concurrently": "10.0.3",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "4.1.0",
		"prettier-plugin-tailwindcss": "0.8.0"
	}
}
